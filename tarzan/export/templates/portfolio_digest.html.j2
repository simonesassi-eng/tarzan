{# =============================================================================
   Tarzan — Portfolio Digest (email-safe HTML, Jinja2 template)
   =============================================================================

   Context shape (see tarzan/export/newsletter.py::build_context):
     palette          dict of CSS hex colors
     header           {date_short, issue_number, inception_date}
     hero             {total_value, total_pnl_eur, total_pnl_pct,
                       total_pnl_is_positive, unrealized_eur,
                       unrealized_pct, unrealized_is_positive,
                       has_total_pnl, gain_pct, twror_pct,
                       twror_is_positive, invested_value, invested_pct,
                       cash_value, cash_msg, cash_msg_color,
                       week_return_eur, week_return_pct, week_is_positive}
     sparkline        {available, label, is_mountain, start_label,
                       end_label, start_value, end_value, is_positive,
                       bars[], pills[]} — a 30-day mountain/area chart
     smart_insights   list of {icon, color, bg, category, headline, body}
     movers           {available, best, worst, benchmark_name}
     allocation       {rows[], stacked[], tolerance}
     geography        {rows[], stacked[], benchmark_name}
     holdings         {groups[], summary[], total_count}
     performance      {portfolio_row, benchmark_rows[],
                       benchmark_alpha_beta, benchmark_geo}
     risk_profile     {available, headers[], rows[],
                       benchmark_alpha_beta, benchmark_geo}
     optimizer        {available, direction, name, ticker, ...}
     return_contrib   {winners[], laggards[]}
     preheader        str
     footer           {generated_at, version}

   All values are pre-formatted strings so the template is purely presentational.
============================================================================= #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>Tarzan — Portfolio Digest</title>
  <style>
    body { margin: 0; padding: 0; background: {{ palette.page }}; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Roboto, Helvetica, Arial, sans-serif; }
    table { border-collapse: collapse; }
    img { display: block; border: 0; }
    a { color: {{ palette.accent }}; text-decoration: none; }
    @media only screen and (max-width: 620px) {
      .container { width: 100% !important; }
      .kpi-cell  { display: block !important; width: 100% !important; box-sizing: border-box; }
      .px-32     { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background:{{ palette.page }};font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Inter',Roboto,Helvetica,Arial,sans-serif;color:{{ palette.ink }};">

  {# -- Preheader (hidden, shown as preview text in inbox) -- #}
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">{{ preheader }}</div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:{{ palette.page }};">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;background:#FFFFFF;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(15,23,42,0.06);">

          {# ─── HEADER ───────────────────────────────────────── #}
          <tr>
            <td class="px-32" style="padding:28px 32px 20px 32px;background:#FFFFFF;border-bottom:1px solid {{ palette.border }};">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="left" style="vertical-align:middle;">
                    <div style="font-size:14px;font-weight:700;letter-spacing:0.04em;color:{{ palette.accent }};text-transform:uppercase;">🌿&nbsp;Tarzan</div>
                    <div style="margin-top:4px;font-size:22px;font-weight:700;color:{{ palette.ink }};line-height:1.2;">Portfolio Digest</div>
                  </td>
                  <td align="right" style="vertical-align:middle;font-size:12px;color:{{ palette.muted }};line-height:1.4;">
                    <div>{{ header.date_short }}</div>
                    <div>Issue #{{ header.issue_number }}</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          {# ─── STATUS ─────────────────────────────────────── #}
          {# Big number + brief return chip + 3 mini-tiles +
             sparkline. Two-fold layout (Sketch C): everything
             monitoring lives here; everything actionable lives
             below in "Signals". #}
          <tr>
            <td class="px-32" style="padding:28px 32px 8px 32px;background:#FFFFFF;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Status</div>
              <div style="margin-top:6px;font-size:40px;font-weight:700;color:{{ palette.ink }};line-height:1.05;letter-spacing:-0.01em;">{{ hero.total_value }}</div>
              <div style="margin-top:6px;font-size:13px;color:{{ palette.ink }};">
                <span style="color:{{ palette.muted }};">Total PnL&nbsp;</span>
                <span style="color:{{ palette.green if hero.total_pnl_is_positive else palette.red }};font-weight:700;">{{ '▲' if hero.total_pnl_is_positive else '▼' }} {{ hero.total_pnl_eur }} ({{ hero.total_pnl_pct }})</span>
                {% if hero.has_total_pnl %}
                <span style="color:{{ palette.subtle }};">&nbsp;·&nbsp;</span>
                <span style="color:{{ palette.muted }};">Unrealized&nbsp;</span>
                <span style="color:{{ palette.green if hero.unrealized_is_positive else palette.red }};font-weight:700;">{{ '▲' if hero.unrealized_is_positive else '▼' }} {{ hero.unrealized_eur }} ({{ hero.unrealized_pct }})</span>
                {% endif %}
              </div>
              <div style="margin-top:4px;font-size:13px;color:{{ palette.ink }};">
                {% if hero.twror_pct %}
                <span style="color:{{ palette.muted }};">TWROR&nbsp;</span>
                <span style="color:{{ palette.green if hero.twror_is_positive else palette.red }};font-weight:700;">{{ hero.twror_pct }}</span>
                {% endif %}
                {% if hero.week_return_pct and hero.week_return_pct != '—' %}
                {% if hero.twror_pct %}<span style="color:{{ palette.subtle }};">&nbsp;·&nbsp;</span>{% endif %}
                <span style="color:{{ palette.muted }};">This week&nbsp;</span>
                <span style="color:{{ palette.green if hero.week_is_positive else palette.red }};font-weight:700;">{{ '▲' if hero.week_is_positive else '▼' }} {{ hero.week_return_pct }}</span>
                {% endif %}
              </div>

              {# Three mini-tiles: Invested / Cash / Rebalance #}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px;">
                <tr>
                  <td class="kpi-cell" width="33%" style="vertical-align:top;padding:12px 14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">Invested</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.ink }};">{{ hero.invested_value }}</div>
                  </td>
                  <td width="6"></td>
                  <td class="kpi-cell" width="33%" style="vertical-align:top;padding:12px 14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">Cash</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.ink }};">{{ hero.cash_value }}</div>
                    <div style="margin-top:2px;font-size:11px;color:{{ hero.cash_msg_color }};">{{ hero.cash_msg }}</div>
                  </td>
                  <td width="6"></td>
                  <td class="kpi-cell" width="33%" style="vertical-align:top;padding:12px 14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">Rebalance</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ hero.rebal_color }};">● {{ hero.rebal_label }}</div>
                    <div style="margin-top:2px;font-size:11px;color:{{ palette.muted }};">{{ hero.rebal_sublabel }}</div>
                  </td>
                </tr>
              </table>

              {# Mountain chart — real patrimony value over the window #}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                <tr>
                  <td style="padding:12px 14px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="vertical-align:middle;"><div style="font-size:10px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">{{ sparkline.label }}</div></td>
                        <td align="right" style="vertical-align:middle;">
                          <span style="font-size:11px;color:{{ palette.muted }};">{{ sparkline.start_value }}</span>
                          <span style="font-size:11px;color:{{ palette.subtle }};">&nbsp;→&nbsp;</span>
                          <span style="font-size:11px;color:{{ palette.ink }};font-weight:700;">{{ sparkline.end_value }}</span>
                          {% for pill in sparkline.pills %}
                          <span style="display:inline-block;margin-left:4px;padding:1px 6px;background:{{ pill.bg }};color:{{ pill.color }};border-radius:4px;font-size:10px;font-weight:700;">{{ pill.text }}</span>
                          {% endfor %}
                        </td>
                      </tr>
                    </table>
                    {# Gap-less adjacent bars form an email-safe area/mountain
                       silhouette. A linear-gradient fill degrades to the solid
                       accent color in clients (Gmail) that strip gradients. #}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:8px;border-collapse:collapse;">
                      <tr style="height:44px;">
                        {% for bar in sparkline.bars %}
                        <td valign="bottom" style="width:{{ 100 / sparkline.bars|length }}%;font-size:0;line-height:0;padding:0;"><div style="background-color:{{ palette.accent }};background:linear-gradient(180deg,{{ palette.accent }} 0%,{{ palette.accent_bg }} 100%);height:{{ bar.height }}px;font-size:0;line-height:0;">&nbsp;</div></td>
                        {% endfor %}
                      </tr>
                    </table>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:6px;">
                      <tr>
                        <td style="font-size:10px;color:{{ palette.subtle }};">{{ sparkline.start_label }}</td>
                        <td align="right" style="font-size:10px;color:{{ palette.subtle }};">{{ sparkline.end_label }}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          {# ─── SIGNALS ─────────────────────────────────────── #}
          {# Conditional insights — each slot only renders when there
             is something genuinely worth saying. The Action slot is an
             "Observation" (contextual, not prescriptive); concrete
             trades live in the Optimizer section below. #}
          {% if smart_insights %}
          <tr>
            <td class="px-32" style="padding:24px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Signals</div>
              <div style="margin-top:4px;font-size:13px;color:{{ palette.muted }};">{{ smart_insights|length }} thing{{ 's' if smart_insights|length != 1 else '' }} worth your attention</div>
              {% for ins in smart_insights %}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:{{ '12px' if loop.first else '6px' }};background:#FFFFFF;border:1px solid {{ palette.border }};border-left:4px solid {{ ins.color }};border-radius:8px;">
                <tr>
                  <td style="padding:10px 14px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="vertical-align:top;width:32px;">
                          <div style="width:24px;height:24px;background:{{ ins.bg }};border-radius:6px;text-align:center;line-height:24px;font-size:13px;color:{{ ins.color }};font-weight:700;">{{ ins.icon }}</div>
                        </td>
                        <td style="vertical-align:top;padding-left:8px;">
                          <div style="font-size:9px;font-weight:700;letter-spacing:0.06em;color:{{ ins.color }};text-transform:uppercase;">{{ ins.category }}</div>
                          <div style="margin-top:2px;font-size:13px;font-weight:600;color:{{ palette.ink }};line-height:1.4;">{{ ins.headline }}</div>
                          <div style="margin-top:3px;font-size:11px;color:{{ palette.muted }};line-height:1.45;">{{ ins.body }}</div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {% endfor %}
            </td>
          </tr>
          {% endif %}


          {# ─── DIVERSIFICATION (Asset Class + Geography, donut layout) ───── #}
          {% if allocation.rows or geography.rows %}
          <tr>
            <td class="px-32" style="padding:28px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Diversification</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">How your portfolio is spread</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">
                Tolerance ±{{ allocation.tolerance }} &nbsp;·&nbsp;
                <span style="color:{{ palette.green }};font-weight:600;">●</span> aligned &nbsp;·&nbsp;
                <span style="color:{{ palette.amber }};font-weight:600;">●</span> drift &nbsp;·&nbsp;
                <span style="color:{{ palette.red }};font-weight:600;">●</span> action
              </div>

              {% if allocation.rows %}
              {# ── BY ASSET CLASS — donut + tabular list (same style
                 as Geography below for visual consistency) ── #}
              <div style="margin-top:18px;font-size:11px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">By asset class</div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:10px;">
                <tr>
                  <td width="180" valign="middle" style="padding-right:18px;">
                    {# CSS conic-gradient donut. Modern Gmail/Apple Mail
                       render this natively; legacy Outlook desktop falls
                       back to a flat-color disc, which is acceptable. #}
                    {% set ns = namespace(acc=0) %}
                    {% set total = allocation.stacked|sum(attribute='width') or 100 %}
                    <div style="width:160px;height:160px;border-radius:50%;background:conic-gradient({% for seg in allocation.stacked %}{{ seg.color }} {{ ns.acc }}% {{ ns.acc + (seg.width / total * 100) }}%{% set ns.acc = ns.acc + (seg.width / total * 100) %}{% if not loop.last %},{% endif %}{% endfor %});position:relative;margin:0 auto;">
                      <div style="position:absolute;top:50%;left:50%;width:96px;height:96px;background:#FFFFFF;border-radius:50%;transform:translate(-50%,-50%);text-align:center;line-height:96px;font-size:11px;color:{{ palette.muted }};font-weight:600;letter-spacing:0.06em;text-transform:uppercase;">Invested</div>
                    </div>
                  </td>
                  <td valign="middle">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:13px;border-collapse:collapse;">
                      <tr>
                        <td style="padding:0 0 6px 0;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Asset</td>
                        <td align="right" style="padding:0 0 6px 0;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">You</td>
                        <td align="right" width="60" style="padding:0 0 6px 8px;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Tgt</td>
                        <td align="right" width="60" style="padding:0 0 6px 6px;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Δ vs tgt</td>
                      </tr>
                      {% for r in allocation.rows %}{% if not r.is_eur %}
                      <tr>
                        <td style="padding:5px 0;border-top:1px solid #F1F2F8;"><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:{{ r.color }};vertical-align:middle;"></span> <span style="font-weight:600;color:{{ r.color }};vertical-align:middle;">{{ r.name }}</span></td>
                        <td align="right" style="padding:5px 0;border-top:1px solid #F1F2F8;font-variant-numeric:tabular-nums;font-weight:700;color:{{ palette.ink }};">{{ r.actual_pct }}</td>
                        <td align="right" width="60" style="padding:5px 0 5px 8px;border-top:1px solid #F1F2F8;font-size:11px;color:{{ palette.muted }};font-variant-numeric:tabular-nums;">{{ r.target_pct }}</td>
                        <td align="right" width="60" style="padding:5px 0 5px 6px;border-top:1px solid #F1F2F8;font-size:11px;font-weight:700;color:{{ r.delta_color }};">●&nbsp;{{ r.delta }}</td>
                      </tr>
                      {% endif %}{% endfor %}
                      {# Cash row — same 4-column layout, slightly
                         heavier separator above so it reads as a
                         distinct accounting bucket. #}
                      {% for r in allocation.rows %}{% if r.is_eur %}
                      <tr>
                        <td style="padding:8px 0 5px 0;border-top:2px solid {{ palette.border }};"><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:{{ r.color }};vertical-align:middle;"></span> <span style="font-weight:600;color:{{ r.color }};vertical-align:middle;">{{ r.name }}</span></td>
                        <td align="right" style="padding:8px 0 5px 0;border-top:2px solid {{ palette.border }};font-variant-numeric:tabular-nums;font-weight:700;color:{{ palette.ink }};">{{ r.actual_pct }}</td>
                        <td align="right" width="60" style="padding:8px 0 5px 8px;border-top:2px solid {{ palette.border }};font-size:11px;color:{{ palette.muted }};font-variant-numeric:tabular-nums;">{{ r.target_pct }}</td>
                        <td align="right" width="60" style="padding:8px 0 5px 6px;border-top:2px solid {{ palette.border }};font-size:11px;font-weight:700;color:{{ r.delta_color }};">●&nbsp;{{ r.delta }}</td>
                      </tr>
                      {% endif %}{% endfor %}
                    </table>
                  </td>
                </tr>
              </table>
              {% endif %}

              {% if geography.rows %}
              {# ── BY GEOGRAPHY — donut + tabular list with ACWI column ── #}
              <div style="margin-top:24px;font-size:11px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">By geography <span style="font-weight:500;color:{{ palette.subtle }};letter-spacing:0;text-transform:none;">— equity portion</span></div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:10px;">
                <tr>
                  <td width="180" valign="middle" style="padding-right:18px;">
                    {% set ns = namespace(acc=0) %}
                    {% set total = geography.stacked|sum(attribute='width') or 100 %}
                    <div style="width:160px;height:160px;border-radius:50%;background:conic-gradient({% for seg in geography.stacked %}{{ seg.color }} {{ ns.acc }}% {{ ns.acc + (seg.width / total * 100) }}%{% set ns.acc = ns.acc + (seg.width / total * 100) %}{% if not loop.last %},{% endif %}{% endfor %});position:relative;margin:0 auto;">
                      <div style="position:absolute;top:50%;left:50%;width:96px;height:96px;background:#FFFFFF;border-radius:50%;transform:translate(-50%,-50%);text-align:center;line-height:96px;font-size:11px;color:{{ palette.muted }};font-weight:600;letter-spacing:0.06em;text-transform:uppercase;">Equity</div>
                    </div>
                  </td>
                  <td valign="middle">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:13px;border-collapse:collapse;">
                      <tr>
                        <td style="padding:0 0 6px 0;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Region</td>
                        <td align="right" style="padding:0 0 6px 0;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">You</td>
                        <td align="right" width="50" style="padding:0 0 6px 6px;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Tgt</td>
                        <td align="right" width="50" style="padding:0 0 6px 6px;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">{{ geography.benchmark_name }}</td>
                        <td align="right" width="60" style="padding:0 0 6px 6px;font-size:9px;font-weight:700;color:{{ palette.muted }};letter-spacing:0.04em;text-transform:uppercase;">Δ vs tgt</td>
                      </tr>
                      {% for r in geography.rows %}
                      <tr>
                        <td style="padding:5px 0;border-top:1px solid #F1F2F8;"><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:{{ r.color }};vertical-align:middle;"></span> <span style="font-weight:600;color:{{ r.color }};vertical-align:middle;">{{ r.name|truncate(22, true, '…') }}</span></td>
                        <td align="right" style="padding:5px 0;border-top:1px solid #F1F2F8;font-variant-numeric:tabular-nums;font-weight:700;color:{{ palette.ink }};">{{ r.actual_pct }}</td>
                        <td align="right" width="50" style="padding:5px 0 5px 6px;border-top:1px solid #F1F2F8;font-variant-numeric:tabular-nums;color:{{ palette.muted }};font-size:11px;">{{ r.target_pct }}</td>
                        <td align="right" width="50" style="padding:5px 0 5px 6px;border-top:1px solid #F1F2F8;font-variant-numeric:tabular-nums;color:{{ palette.subtle }};font-size:11px;">{{ r.acwi_pct }}</td>
                        <td align="right" width="60" style="padding:5px 0 5px 6px;border-top:1px solid #F1F2F8;font-size:11px;font-weight:700;color:{{ r.delta_color }};">●&nbsp;{{ r.delta }}</td>
                      </tr>
                      {% endfor %}
                    </table>
                  </td>
                </tr>
              </table>
              {% endif %}
            </td>
          </tr>
          {% endif %}

          {# ─── HOLDINGS (grouped by class, compact rows) ────── #}
          {% if holdings.groups %}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Holdings</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">All positions</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">{{ holdings.total_count }} holdings &nbsp;·&nbsp; {{ hero.total_value }} total</div>

              {# Summary chips by asset class #}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;">
                <tr>
                  {% for s in holdings.summary %}
                  <td class="kpi-cell" style="vertical-align:top;padding:10px 12px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:600;letter-spacing:0.04em;color:{{ s.color }};text-transform:uppercase;">● {{ s.name|truncate(12, true, '') }}</div>
                    <div style="margin-top:2px;font-size:14px;font-weight:700;color:{{ palette.ink }};">{{ s.count }} <span style="color:{{ palette.muted }};font-size:11px;font-weight:600;">{{ s.label }}</span></div>
                  </td>
                  {% if not loop.last %}<td width="6"></td>{% endif %}
                  {% endfor %}
                </tr>
              </table>

              {# Grouped holdings table — one block per asset class with
                 a thin colored header strip carrying the group summary,
                 then compact 5-column rows: name+ticker · Value · Weight
                 (% portfolio) · % Class · Gain. #}
              {% for g in holdings.groups %}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:{{ '18px' if loop.first else '14px' }};border:1px solid {{ palette.border }};border-radius:10px;overflow:hidden;font-size:12px;">
                {# Group header: subtle separator strip with class name +
                   summary on the right. Lighter than the previous full
                   colored block which felt too loud. #}
                <tr>
                  <td colspan="5" style="padding:8px 12px 8px 14px;background:#FFFFFF;border-bottom:1px solid {{ palette.border }};border-left:4px solid {{ g.color }};">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="vertical-align:middle;font-size:11px;font-weight:700;letter-spacing:0.04em;color:{{ g.color }};text-transform:uppercase;">{{ g.name }}</td>
                        <td align="right" style="vertical-align:middle;font-size:11px;color:{{ palette.muted }};font-variant-numeric:tabular-nums;">{{ g.count }} {{ g.label }} &nbsp;·&nbsp; {{ g.total_value }}{% if g.total_pct %} &nbsp;·&nbsp; {{ g.total_pct }} of invested{% endif %}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {# Column headers #}
                <tr>
                  <td style="padding:6px 12px 6px 14px;background:{{ palette.card_alt }};border-bottom:1px solid {{ palette.border }};border-left:4px solid {{ g.color }};font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;">Holding</td>
                  <td align="right" style="padding:6px 6px;background:{{ palette.card_alt }};border-bottom:1px solid {{ palette.border }};font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;width:80px;">Value €</td>
                  <td align="right" style="padding:6px 6px;background:{{ palette.card_alt }};border-bottom:1px solid {{ palette.border }};font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;width:62px;">% Inv.</td>
                  <td align="right" style="padding:6px 6px;background:{{ palette.card_alt }};border-bottom:1px solid {{ palette.border }};font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;width:54px;">% Class</td>
                  <td align="right" style="padding:6px 12px 6px 6px;background:{{ palette.card_alt }};border-bottom:1px solid {{ palette.border }};font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;width:60px;">Gain</td>
                </tr>
                {# Holding rows #}
                {% for r in g.rows %}
                <tr>
                  <td style="padding:8px 12px 8px 14px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}border-left:4px solid {{ g.color }};">
                    <div style="font-size:12px;font-weight:600;color:{{ palette.ink }};line-height:1.3;">{{ r.name|truncate(48, true, '…') }}</div>
                    <div style="margin-top:2px;font-size:10px;color:{{ palette.muted }};line-height:1.3;">{{ r.ticker }}</div>
                  </td>
                  <td align="right" style="padding:8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;font-weight:600;color:{{ palette.ink }};">{{ r.value }}</td>
                  <td align="right" style="padding:8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.ink }};">{{ r.weight_pct }}</td>
                  <td align="right" style="padding:8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ g.color }};font-weight:600;">{{ r.pct_class }}</td>
                  <td align="right" style="padding:8px 12px 8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ r.gain_color }};font-weight:700;">{{ r.gain_pct }}</td>
                </tr>
                {% endfor %}
              </table>
              {% endfor %}
            </td>
          </tr>
          {% endif %}

          {# ─── RETURNS SNAPSHOT (per-holding × period) ─────── #}
          {% if returns_snapshot.available %}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Returns snapshot</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">How each holding is moving</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">Per-instrument returns are the security's own market return over each window (a 5Y column shows the full 5 years even if you've held it less), colored by sign. Your <strong>Total Portfolio</strong> row is the consolidated history, capped to the youngest holding with ≥1Y of data — currently <strong>{{ returns_snapshot.history_label }}</strong> — so longer periods show "—"; its cells are colored by delta vs <strong>{{ returns_snapshot.benchmark_alpha_beta }}</strong> (<span style="color:{{ palette.green }};font-weight:700;">●</span> beat · <span style="color:{{ palette.amber }};font-weight:700;">●</span> in line · <span style="color:{{ palette.red }};font-weight:700;">●</span> under). Holdings with &lt;1Y of history don't shorten it.</div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;font-size:11px;border-collapse:separate;border-spacing:0;">
                <tr>
                  <td style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;border-top-left-radius:8px;">Instrument</td>
                  {% for p in returns_snapshot.period_labels %}
                  <td align="right" style="padding:8px 6px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;{% if loop.last %}border-top-right-radius:8px;{% endif %}">{{ p|upper }}</td>
                  {% endfor %}
                </tr>
                {% for r in returns_snapshot.rows %}
                {% if r.is_portfolio %}
                {# Portfolio row (highlighted) — same styling as the Performance table below. #}
                <tr>
                  <td style="padding:10px 8px;background:{{ palette.accent_bg }};color:{{ palette.accent }};font-weight:700;font-size:12px;">★ {{ r.name }}</td>
                  {% for c in r.cells %}
                  <td align="right" style="padding:10px 6px;background:{{ palette.accent_bg }};font-variant-numeric:tabular-nums;color:{{ c.color }};font-weight:700;">{{ c.value }}</td>
                  {% endfor %}
                </tr>
                {% else %}
                <tr>
                  <td style="padding:8px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}color:{{ palette.ink }};{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">
                    {{ r.name }}
                  </td>
                  {% for c in r.cells %}
                  <td align="right" style="padding:8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ c.color }};font-weight:600;">{{ c.value }}</td>
                  {% endfor %}
                </tr>
                {% endif %}
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          {# ─── PERFORMANCE — RETURNS TABLE ──────────────────── #}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Performance</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">Returns vs benchmarks</div>
              {% if performance.returns %}
              {# XIRR / TWROR chips — only when an order list drove them. #}
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top:10px;">
                <tr>
                  {% if performance.returns.xirr %}
                  <td style="padding:6px 12px;background:{{ palette.accent_bg }};border-radius:8px;">
                    <div style="font-size:9px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">XIRR · money-weighted</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.accent }};">{{ performance.returns.xirr }}</div>
                  </td>
                  <td width="8"></td>
                  {% endif %}
                  {% if performance.returns.twror %}
                  <td style="padding:6px 12px;background:{{ palette.accent_bg }};border-radius:8px;">
                    <div style="font-size:9px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">TWROR · time-weighted</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.accent }};">{{ performance.returns.twror }}{% if performance.returns.twror_annualized %} <span style="font-size:11px;font-weight:600;color:{{ palette.muted }};">({{ performance.returns.twror_annualized }} ann.)</span>{% endif %}</div>
                  </td>
                  {% endif %}
                </tr>
              </table>
              {% if performance.returns.coverage %}
              <div style="margin-top:6px;font-size:11px;color:{{ palette.subtle }};">Computed on {{ performance.returns.coverage }} real market data{% if performance.returns.fallback_count %} · {{ performance.returns.fallback_count }} instrument{{ 's' if performance.returns.fallback_count != 1 else '' }} priced by fallback{% endif %}.</div>
              {% endif %}
              {% endif %}
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">All values in %. Benchmarks span the full 5Y window; your portfolio history is <strong>{{ performance.history_label }}</strong> — periods longer than that show "—" for the portfolio row. Portfolio cells colored by delta vs <strong>{{ performance.benchmark_alpha_beta }}</strong>: <span style="color:{{ palette.green }};font-weight:700;">●</span> beat &nbsp;·&nbsp; <span style="color:{{ palette.amber }};font-weight:700;">●</span> in line (±0.25 pp) &nbsp;·&nbsp; <span style="color:{{ palette.red }};font-weight:700;">●</span> underperform.</div>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;font-size:11px;border-collapse:separate;border-spacing:0;">
                <tr>
                  <td style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;border-top-left-radius:8px;">Instrument</td>
                  {% for p in performance.periods %}
                  <td align="right" style="padding:8px 6px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;{% if loop.last %}border-top-right-radius:8px;{% endif %}">{{ p|upper }}</td>
                  {% endfor %}
                </tr>
                {# Portfolio row (highlighted) #}
                <tr>
                  <td style="padding:10px 8px;background:{{ palette.accent_bg }};color:{{ palette.accent }};font-weight:700;font-size:12px;">★ {{ performance.portfolio_row.name }}</td>
                  {% for p in performance.periods %}
                  <td align="right" style="padding:10px 6px;background:{{ palette.accent_bg }};font-variant-numeric:tabular-nums;color:{{ performance.portfolio_row.returns[p].color }};font-weight:700;">{{ performance.portfolio_row.returns[p].value }}</td>
                  {% endfor %}
                </tr>
                {% for r in performance.benchmark_rows %}
                <tr>
                  <td style="padding:8px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}color:{{ palette.ink }};{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">
                    {{ r.name }}
                    {% for t in r.tags %}<span style="display:inline-block;margin-left:4px;padding:1px 6px;background:{{ t[2] }};color:{{ t[1] }};border-radius:4px;font-size:9px;font-weight:700;letter-spacing:0.04em;">{{ t[0] }}</span>{% endfor %}
                  </td>
                  {% for p in performance.periods %}
                  <td align="right" style="padding:8px 6px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};font-variant-numeric:tabular-nums;color:{{ r.returns[p].color }};font-weight:600;">{{ r.returns[p].value }}</td>
                  {% endfor %}
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>

          {# ─── RISK PROFILE — UNIFIED TABLE ────────────────── #}
          {% if risk_profile.available %}
          <tr>
            <td class="px-32" style="padding:24px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Risk profile</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">How risky is your ride</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">Computed on the last 5 years of portfolio history (capped); holdings with &lt;1Y of data are excluded. ▲ = portfolio better than {{ risk_profile.benchmark_alpha_beta }}, ▼ = worse.</div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;font-size:12px;border-collapse:separate;border-spacing:0;">
                <tr>
                  {% for h in risk_profile.headers %}
                  <td {% if loop.index > 1 %}align="right"{% endif %} style="padding:8px 10px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;{% if loop.first %}border-top-left-radius:8px;{% endif %}{% if loop.last %}border-top-right-radius:8px;{% endif %}">{{ h }}</td>
                  {% endfor %}
                </tr>
                {% for r in risk_profile.rows %}
                <tr>
                  <td style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}color:{{ palette.ink }};{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">{{ r.label }}</td>
                  <td align="right" style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;font-weight:700;color:{{ palette.ink }};">
                    {{ r.you }}{% if r.verdict_sp %} <span style="color:{{ r.verdict_sp_color }};font-weight:700;">{{ r.verdict_sp }}</span>{% endif %}
                  </td>
                  <td align="right" style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.muted }};">{{ r.sp500 }}</td>
                  <td align="right" style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.muted }};{% if loop.last %}border-bottom-right-radius:8px;{% endif %}">{{ r.acwi }}</td>
                </tr>
                {% endfor %}
              </table>

              {# Legend — same content as the Excel Performance tab Legend #}
              {% if risk_profile.legend %}
              <div style="margin-top:18px;font-size:11px;font-weight:700;letter-spacing:0.06em;color:{{ palette.muted }};text-transform:uppercase;">Legend — what these metrics mean</div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:6px;font-size:11px;border-collapse:separate;border-spacing:0;">
                {% for r in risk_profile.legend %}
                <tr>
                  <td style="padding:8px 10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}color:{{ palette.ink }};font-weight:600;vertical-align:top;width:120px;{% if loop.first %}border-top-left-radius:8px;{% endif %}{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">{{ r.label }}</td>
                  <td style="padding:8px 10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid #F1F2F8;{% endif %}color:{{ palette.muted }};font-size:11px;line-height:1.5;vertical-align:top;{% if loop.first %}border-top-right-radius:8px;{% endif %}{% if loop.last %}border-bottom-right-radius:8px;{% endif %}">
                    {{ r.description }}
                    <div style="margin-top:4px;font-variant-numeric:tabular-nums;font-size:10px;">
                      <span style="color:{{ palette.green }};font-weight:700;">● {{ r.strong }}</span>
                      &nbsp;·&nbsp;
                      <span style="color:{{ palette.amber }};font-weight:700;">● {{ r.fair }}</span>
                      &nbsp;·&nbsp;
                      <span style="color:{{ palette.red }};font-weight:700;">● {{ r.weak }}</span>
                    </div>
                  </td>
                </tr>
                {% endfor %}
              </table>
              {% endif %}
            </td>
          </tr>
          {% endif %}

          {# ─── OPTIMIZER ACTION ──────────────────────────── #}
          {% if optimizer.available %}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Optimizer</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">Suggested action{% if optimizer.n_total != 1 %}s{% endif %}</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};">
                {{ optimizer.n_buy }} BUY &nbsp;·&nbsp; {{ optimizer.n_sell }} SELL &nbsp;·&nbsp; total
                <span style="color:{{ palette.green }};font-weight:600;">{{ optimizer.total_buy }}</span> in,
                <span style="color:{{ palette.red }};font-weight:600;">{{ optimizer.total_sell }}</span> out,
                net <span style="color:{{ optimizer.net_color }};font-weight:600;">{{ optimizer.net }}</span>
              </div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;font-size:12px;border-collapse:separate;border-spacing:0;">
                <tr>
                  <td style="padding:8px 10px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;border-top-left-radius:8px;width:60px;">Action</td>
                  <td style="padding:8px 10px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;">Holding</td>
                  <td align="right" style="padding:8px 10px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;width:90px;">Amount</td>
                  <td align="right" style="padding:8px 10px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;width:60px;border-top-right-radius:8px;">% Port.</td>
                </tr>
                {% for a in optimizer.actions %}
                <tr>
                  <td style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}vertical-align:top;{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">
                    <span style="display:inline-block;padding:3px 8px;background:{{ a.direction_bg }};color:{{ a.direction_color }};border-radius:999px;font-weight:700;font-size:10px;letter-spacing:0.04em;">{{ a.direction }}</span>
                  </td>
                  <td style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}vertical-align:top;color:{{ palette.ink }};">
                    <div style="font-weight:600;line-height:1.3;">{{ a.name }}</div>
                    <div style="margin-top:2px;font-size:11px;color:{{ palette.muted }};">{{ a.ticker }} · <span style="color:{{ a.asset_color }};font-weight:600;">● {{ a.asset_class }}</span></div>
                    {% if a.reason %}
                    <div style="margin-top:4px;font-size:10px;color:{{ palette.subtle }};line-height:1.45;">{{ a.reason }}</div>
                    {% endif %}
                  </td>
                  <td align="right" style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}vertical-align:top;font-variant-numeric:tabular-nums;font-weight:700;color:{{ a.direction_color }};">{{ a.amount }}</td>
                  <td align="right" style="padding:10px;background:{% if loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}vertical-align:top;font-variant-numeric:tabular-nums;color:{{ palette.muted }};{% if loop.last %}border-bottom-right-radius:8px;{% endif %}">{{ a.pct_of_portfolio }}</td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          {# ─── DRIFT-PENALTY SENSITIVITY ──────────────── #}
          {% if sensitivity.available %}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Tuning</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">Drift-penalty sensitivity</div>
              <div style="margin-top:4px;font-size:12px;color:{{ palette.muted }};line-height:1.45;">
                Each row is a regime — a range of weights producing the same plan. Your active weight is
                <span style="color:{{ palette.ink }};font-weight:700;">{{ sensitivity.active_weight }}</span>
                (highlighted with ▶). Higher weights close more drift at the cost of more trades, taxes, and fees.
              </div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;font-size:11px;border-collapse:separate;border-spacing:0;">
                <tr>
                  <td style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;border-top-left-radius:8px;">Weight</td>
                  <td style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;">Trades</td>
                  <td align="right" style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;">Buy</td>
                  <td align="right" style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;">Sell</td>
                  <td align="right" style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;">Tax+Fee</td>
                  <td align="right" style="padding:8px 8px;background:{{ palette.ink }};color:#FFFFFF;font-size:10px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;border-top-right-radius:8px;">Drift</td>
                </tr>
                {% for r in sensitivity.rows %}
                <tr>
                  <td style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-weight:{% if r.is_active %}700{% else %}500{% endif %};color:{{ palette.ink }};{% if loop.last %}border-bottom-left-radius:8px;{% endif %}">{% if r.is_active %}▶ {% endif %}{{ r.weight_range }}</td>
                  <td style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}color:{{ palette.muted }};">{{ r.actions }}</td>
                  <td align="right" style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.green }};font-weight:600;">{{ r.buy_total }}</td>
                  <td align="right" style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.red }};font-weight:600;">{{ r.sell_total }}</td>
                  <td align="right" style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.muted }};">{{ r.friction }}</td>
                  <td align="right" style="padding:8px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-variant-numeric:tabular-nums;color:{{ palette.ink }};font-weight:600;{% if loop.last %}border-bottom-right-radius:8px;{% endif %}">{{ r.max_drift }}</td>
                </tr>
                {% if r.net_by_class and r.net_by_class != '—' %}
                <tr>
                  <td colspan="6" style="padding:0 10px 8px 10px;background:{% if r.is_active %}{{ palette.accent_bg }}{% elif loop.index is odd %}#FFFFFF{% else %}{{ palette.card_alt }}{% endif %};{% if not loop.last %}border-bottom:1px solid {{ palette.border }};{% endif %}font-size:10px;color:{{ palette.subtle }};line-height:1.4;">
                    <span style="color:{{ palette.muted }};font-weight:600;">Net change:</span> {{ r.net_by_class }}
                  </td>
                </tr>
                {% endif %}
                {% endfor %}
              </table>
              {% if sensitivity.notes %}
              <div style="margin-top:12px;padding:12px 14px;background:{{ palette.card_alt }};border-radius:8px;font-size:11px;color:{{ palette.muted }};line-height:1.6;">
                {% for note in sensitivity.notes %}
                <div{% if not loop.first %} style="margin-top:4px;"{% endif %}>{{ note }}</div>
                {% endfor %}
              </div>
              {% endif %}
            </td>
          </tr>
          {% endif %}

          {# ─── RETURN CONTRIBUTION ──────────────────────── #}
          {% if return_contrib.winners or return_contrib.laggards %}
          <tr>
            <td class="px-32" style="padding:32px 32px 0 32px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Return contribution</div>
              <div style="margin-top:4px;font-size:18px;font-weight:700;color:{{ palette.ink }};">Who moved the needle</div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;">
                <tr>
                  <td class="kpi-cell" width="50%" valign="top" style="padding-right:8px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F0FDF4;border:1px solid {{ palette.green_border }};border-radius:12px;">
                      <tr><td style="padding:14px 16px 10px 16px;"><div style="font-size:11px;font-weight:700;letter-spacing:0.06em;color:{{ palette.green }};text-transform:uppercase;">▲ Top winners</div></td></tr>
                      <tr><td style="padding:0 16px 8px 16px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:12px;">
                          {% for w in return_contrib.winners %}
                          <tr>
                            <td style="padding:6px 0;color:{{ palette.ink }};{% if not loop.first %}border-top:1px solid {{ palette.green_bg }};{% endif %}">{{ w.name|truncate(28, true, '…') }}</td>
                            <td align="right" style="padding:6px 0;font-weight:700;color:{{ palette.green }};font-variant-numeric:tabular-nums;{% if not loop.first %}border-top:1px solid {{ palette.green_bg }};{% endif %}">{{ w.value }}</td>
                          </tr>
                          {% endfor %}
                        </table>
                      </td></tr>
                    </table>
                  </td>
                  <td class="kpi-cell" width="50%" valign="top" style="padding-left:8px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FEF2F2;border:1px solid {{ palette.red_border }};border-radius:12px;">
                      <tr><td style="padding:14px 16px 10px 16px;"><div style="font-size:11px;font-weight:700;letter-spacing:0.06em;color:{{ palette.red }};text-transform:uppercase;">▼ Laggards</div></td></tr>
                      <tr><td style="padding:0 16px 8px 16px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:12px;">
                          {% for l in return_contrib.laggards %}
                          <tr>
                            <td style="padding:6px 0;color:{{ palette.ink }};{% if not loop.first %}border-top:1px solid #FEE2E2;{% endif %}">{{ l.name|truncate(28, true, '…') }}</td>
                            <td align="right" style="padding:6px 0;font-weight:700;color:{{ palette.red }};font-variant-numeric:tabular-nums;{% if not loop.first %}border-top:1px solid #FEE2E2;{% endif %}">{{ l.value }}</td>
                          </tr>
                          {% endfor %}
                        </table>
                      </td></tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          {# ─── FOOTER ────────────────────────────────────── #}
          <tr>
            <td class="px-32" style="padding:24px 32px 32px 32px;border-top:1px solid {{ palette.border }};">
              <div style="font-size:11px;color:{{ palette.muted }};line-height:1.6;text-align:center;">
                Generated {{ footer.generated_at }} · Tarzan {{ footer.version }}<br>
                {{ holdings.total_count }} holdings tracked · also exported as Excel report<br>
                Personal portfolio analytics. Not investment advice.
              </div>
            </td>
          </tr>

        </table>
        <div style="margin-top:14px;font-size:11px;color:{{ palette.subtle }};">🌿 Tarzan — Built for the long swing.</div>
      </td>
    </tr>
  </table>
</body>
</html>

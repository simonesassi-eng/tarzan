{# Status variant 6 — "Hybrid" (v2 + v5), refined:
   1) chart-led hero card: value + Cash (small) on the left, Unrealized PnL
      on the right, full-bleed mountain with a 4-point dated X-axis;
   2) return scoreboard: YOUR MONEY (PnL) vs MARKET · TIME-WEIGHTED (TWROR),
      each with an annualized subtitle (XIRR / TWROR-ann.) and three rows by
      period — since inception / last 7 days / last 30 days;
   3) a v4-style rebalance banner, only when action is needed. #}
          <tr>
            <td class="px-32" style="padding:28px 32px 8px 32px;background:#FFFFFF;">

              {# 1 ── Chart-led hero card #}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:12px;">
                <tr>
                  <td style="padding:16px 16px 12px 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="vertical-align:top;">
                          <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;color:{{ palette.accent }};text-transform:uppercase;">Portfolio{% if hero.inception_label %} · since {{ hero.inception_label }}{% endif %}</div>
                          <div style="margin-top:4px;font-size:36px;font-weight:700;color:{{ palette.ink }};line-height:1.03;letter-spacing:-0.015em;">{{ hero.total_value }}</div>
                          <div style="margin-top:3px;font-size:11px;color:{{ palette.muted }};">Cash <span style="color:{{ palette.ink }};font-weight:700;">{{ hero.cash_value }}</span></div>
                        </td>
                        {% if hero.has_total_pnl %}
                        <td align="right" style="vertical-align:top;">
                          <div style="font-size:9px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};text-transform:uppercase;">Unrealized PnL</div>
                          <div style="margin-top:2px;font-size:15px;font-weight:700;color:{{ palette.green if hero.unrealized_is_positive else palette.red }};">{{ hero.unrealized_eur }}</div>
                          <div style="font-size:12px;font-weight:700;color:{{ palette.green if hero.unrealized_is_positive else palette.red }};">({{ hero.unrealized_pct }})</div>
                        </td>
                        {% endif %}
                      </tr>
                    </table>
                    {# Full-bleed mountain #}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;border-collapse:collapse;">
                      <tr style="height:58px;">
                        {% for bar in sparkline.bars %}
                        <td valign="bottom" style="width:{{ 100 / sparkline.bars|length }}%;font-size:0;line-height:0;padding:0;"><div style="background-color:{{ palette.accent }};background:linear-gradient(180deg,{{ palette.accent }} 0%,{{ palette.accent_bg }} 100%);height:{{ (bar.height * 1.3)|round|int }}px;font-size:0;line-height:0;">&nbsp;</div></td>
                        {% endfor %}
                      </tr>
                    </table>
                    {# Dated X-axis (start · two interior · end) #}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:5px;">
                      <tr>
                        {% for lbl in sparkline.axis_labels %}
                        <td style="font-size:10px;color:{{ palette.subtle }};" align="{{ 'left' if loop.first else ('right' if loop.last else 'center') }}">{{ lbl }}</td>
                        {% endfor %}
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              {# 2 ── Return scoreboard: Profit & Losses | TWROR #}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;">
                <tr>
                  <td width="49%" style="vertical-align:top;padding:14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:11px;font-weight:700;color:{{ palette.muted }};">Profit &amp; Losses</div>
                    <div style="margin-top:10px;font-size:10px;color:{{ palette.subtle }};">Since inception</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.total_pnl_is_positive else palette.red }};">{{ hero.total_pnl_eur }} ({{ hero.total_pnl_pct }})</div>
                    <div style="margin-top:8px;font-size:10px;color:{{ palette.subtle }};">Last 7 days</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.week_pnl_is_positive else palette.red }};">{{ hero.week_pnl_eur or '—' }}{% if hero.week_pnl_pct %} ({{ hero.week_pnl_pct }}){% endif %}</div>
                    <div style="margin-top:8px;font-size:10px;color:{{ palette.subtle }};">Last 30 days</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.month_pnl_is_positive else palette.red }};">{{ hero.month_pnl_eur or '—' }}{% if hero.month_pnl_pct %} ({{ hero.month_pnl_pct }}){% endif %}</div>
                  </td>
                  <td width="2%"></td>
                  <td width="49%" style="vertical-align:top;padding:14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:11px;font-weight:700;color:{{ palette.muted }};">Time-Weighted Rate of Return</div>
                    <div style="margin-top:10px;font-size:10px;color:{{ palette.subtle }};">Since inception</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.twror_is_positive else palette.red }};">{{ hero.twror_pct or '—' }}</div>
                    <div style="margin-top:8px;font-size:10px;color:{{ palette.subtle }};">Last 7 days</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.week_twror_is_positive else palette.red }};">{{ hero.week_twror_pct or '—' }}</div>
                    <div style="margin-top:8px;font-size:10px;color:{{ palette.subtle }};">Last 30 days</div>
                    <div style="font-size:14px;font-weight:700;color:{{ palette.green if hero.month_twror_is_positive else palette.red }};">{{ hero.month_twror_pct or '—' }}</div>
                  </td>
                </tr>
              </table>

              {# 3 ── Annualized returns in two separate cards (money-weighted
                 XIRR vs time-weighted TWROR), continuing the left/right
                 money-vs-market columns. Shown only when available. #}
              {% if hero.xirr_pct or hero.twror_annualized_pct %}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:8px;">
                <tr>
                  <td width="49%" style="vertical-align:top;padding:10px 14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};">XIRR · annualized</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.ink }};">{{ hero.xirr_pct or '—' }}</div>
                    <div style="font-size:10px;color:{{ palette.subtle }};">money-weighted</div>
                  </td>
                  <td width="2%"></td>
                  <td width="49%" style="vertical-align:top;padding:10px 14px;background:{{ palette.card_alt }};border:1px solid {{ palette.border }};border-radius:10px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.04em;color:{{ palette.muted }};">TWROR · annualized</div>
                    <div style="margin-top:2px;font-size:16px;font-weight:700;color:{{ palette.ink }};">{{ hero.twror_annualized_pct or '—' }}</div>
                    <div style="font-size:10px;color:{{ palette.subtle }};">time-weighted</div>
                  </td>
                </tr>
              </table>
              {% endif %}

              {# 4 ── Slim, colored rebalance banner (only when action is needed) #}
              {% if hero.rebal_label and hero.rebal_label != 'Aligned' %}
              <div style="margin-top:10px;padding:7px 12px;background:{{ hero.rebal_bg }};border-radius:8px;font-size:11px;font-weight:700;color:{{ hero.rebal_color }};">● Rebalance · {{ hero.rebal_n_actions }} action{{ 's' if hero.rebal_n_actions != 1 else '' }} · see optimizer below</div>
              {% endif %}
            </td>
          </tr>
